# =====================================================
# .env.example — szablon zmiennych środowiskowych
# =====================================================
#
# Skopiuj ten plik jako .env.local:
#   cp .env.example .env.local
#
# Następnie wypełnij rzeczywistymi wartościami z panelu Supabase:
#   Project Settings → API → Project URL + anon public key
#
# UWAGA: .env.local jest w .gitignore i NIGDY nie powinien
# trafić do repozytorium. Sekrety wyciekają na zawsze.
#
# =====================================================

# Supabase (publiczne — dostępne w przeglądarce)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase (server-side ONLY — NIE z prefiksem NEXT_PUBLIC)
# Klucz administracyjny — używaj tylko w Server Components / Server Actions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# (opcjonalnie) URL produkcyjny aplikacji — używane w metadata, OG images, emails
NEXT_PUBLIC_SITE_URL=http://localhost:3000
