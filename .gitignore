# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============== Dependencies ==============
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============== Testing ==============
/coverage

# ============== Next.js ==============
/.next/
/out/

# ============== Production builds ==============
/build
/dist

# ============== Misc ==============
.DS_Store
*.pem
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ============== Debug ==============
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============== Environment variables (sekrety!) ==============
# WAŻNE: NIGDY nie commituj plików .env z prawdziwymi sekretami
.env
.env*.local
.env.production
.env.development
# Wyjątek — szablon bez prawdziwych wartości można commitować
!.env.example

# ============== Vercel ==============
.vercel

# ============== TypeScript ==============
*.tsbuildinfo
next-env.d.ts

# ============== Supabase ==============
# Lokalne dane Supabase (uruchamiane przez supabase start)
supabase/.branches/
supabase/.temp/
**/supabase/.env

# ============== Claude Code ==============
# Worktrees dla parallel sessions w Claude Code Desktop
.claude/worktrees/

# Cache pluginów
.claude/cache/

# Lokalne nadpisania settings (nie commitujemy — to per-machine)
.claude/settings.local.json

# Logi i tymczasowe pliki Claude
.claude/logs/
.claude/*.log

# ============== OS files ==============
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============== Editor backups ==============
*~
*.swp
*.swo
*.bak
*.tmp
